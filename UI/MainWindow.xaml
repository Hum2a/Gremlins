<Window x:Class="Gremlins.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Gremlins.UI"
        Title="Gremlins"
        Width="480" Height="640"
        MinWidth="420" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D0F"
        Foreground="#E8E8E8"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:SeverityLabelConverter x:Key="SeverityLabelConverter"/>
    </Window.Resources>

    <Border CornerRadius="12" Background="#0D0D0F"
            BorderBrush="#2A2A32" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar (draggable) -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0"
                    Background="#111114" Padding="20,14"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="👹" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="GREMLINS" FontSize="16" FontWeight="Bold"
                                       Foreground="#39FF14"
                                       FontFamily="Consolas"/>
                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="11" Foreground="#6B6B7A"/>
                        </StackPanel>
                    </StackPanel>

                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Content="✕" Width="28" Height="28"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#6B6B7A" FontSize="13"
                            Cursor="Hand" Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"    Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground"    Value="#6B6B7A"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF3A3A"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="16,10" Background="#0D0D0F">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Enable All"  Style="{StaticResource ActionButtonPrimary}"
                            Command="{Binding EnableAllCommand}" Margin="0,0,10,0"/>
                    <Button Content="Disable All" Style="{StaticResource ActionButtonSecondary}"
                            Command="{Binding DisableAllCommand}"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2" Padding="16,4,16,8"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding GremlinCards}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:GremlinCardViewModel}">
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding Emoji}"
                                               FontSize="28" VerticalAlignment="Center"
                                               Margin="0,0,14,0"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#E8E8E8"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="11" Foreground="#6B6B7A"
                                                   TextWrapping="Wrap" Margin="0,3,0,8"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Severity:" FontSize="11"
                                                       Foreground="#6B6B7A" VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <ComboBox ItemsSource="{Binding Severities}"
                                                      SelectedItem="{Binding Severity}"
                                                      IsEnabled="{Binding IsEnabled}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Foreground="#E8E8E8"
                                                                   Text="{Binding Converter={StaticResource SeverityLabelConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>

                                    <ToggleButton Grid.Column="2"
                                                  Style="{StaticResource ToggleStyle}"
                                                  IsChecked="{Binding IsEnabled}"
                                                  VerticalAlignment="Center"
                                                  Margin="12,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="3" Padding="20,12" Background="#111114"
                    CornerRadius="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="Runs silently in system tray. Close this window to keep gremlins active."
                               FontSize="10" Foreground="#6B6B7A" TextAlignment="Center"
                               TextWrapping="Wrap"/>
                    <CheckBox Margin="0,10,0,0"
                              HorizontalAlignment="Center"
                              Foreground="#6B6B7A"
                              Content="Start with Windows"
                              IsChecked="{Binding StartWithWindows}"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>

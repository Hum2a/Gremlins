<Window x:Class="Gremlins.UI.GremlinSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="440" MinHeight="320" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BrushWindowBg}"
        Foreground="{DynamicResource BrushTextPrimary}"
        FontFamily="Segoe UI"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Padding="18" Background="{DynamicResource BrushBgCard}"
            CornerRadius="10" Margin="8"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Done" Style="{StaticResource ActionButtonPrimary}" Padding="20,10" Click="Done_Click" IsDefault="True"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="440">
                <StackPanel>
                    <!-- Drifter -->
                    <StackPanel Visibility="{Binding ShowDrifter, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom timing &amp; drift (ignore severity presets)"
                                  IsChecked="{Binding Current.Drifter.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"/>
                        <TextBlock Text="Min interval (seconds)" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="10" Maximum="7200" TickFrequency="60" IsSnapToTickEnabled="False"
                                Value="{Binding Current.Drifter.MinIntervalSeconds}" Margin="0,4,0,8"/>
                        <TextBlock Text="Max interval (seconds)" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="10" Maximum="7200"
                                Value="{Binding Current.Drifter.MaxIntervalSeconds}" Margin="0,4,0,8"/>
                        <TextBlock Text="Max drift (pixels per nudge)" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="120"
                                Value="{Binding Current.Drifter.MaxDriftPixels}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Typist -->
                    <StackPanel Visibility="{Binding ShowTypist, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom substitution chance (ignore severity presets)"
                                  IsChecked="{Binding Current.Typist.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"/>
                        <TextBlock Text="Substitution chance (% per eligible key)" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="0.05" Maximum="25" SmallChange="0.05" LargeChange="1"
                                Value="{Binding Current.Typist.SubstitutionChancePercent}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Amnesiac -->
                    <StackPanel Visibility="{Binding ShowAmnesiac, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom clear intervals (ignore severity presets)"
                                  IsChecked="{Binding Current.Amnesiac.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"/>
                        <TextBlock Text="Min minutes between clears" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="240"
                                Value="{Binding Current.Amnesiac.MinIntervalMinutes}" Margin="0,4,0,8"/>
                        <TextBlock Text="Max minutes between clears" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="240"
                                Value="{Binding Current.Amnesiac.MaxIntervalMinutes}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Critic -->
                    <StackPanel Visibility="{Binding ShowCritic, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom poll interval (ignore severity preset timing)"
                                  IsChecked="{Binding Current.Critic.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"/>
                        <TextBlock Text="Foreground window poll interval (seconds)" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="120"
                                Value="{Binding Current.Critic.PollIntervalSeconds}" Margin="0,4,0,10"/>
                        <TextBlock Text="Extra title keywords (comma-separated, matched in window titles)" FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}" TextWrapping="Wrap"/>
                        <TextBox Margin="0,6,0,0" Text="{Binding Current.Critic.ExtraTitleKeywords, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Example: steam,epic games,mygame"/>
                        <TextBlock Text="Sigh volume (generated or custom file)" FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}" Margin="0,14,0,4"/>
                        <Slider Minimum="5" Maximum="100"
                                Value="{Binding Current.Critic.SighVolumePercent}" Margin="0,0,0,10"/>
                        <TextBlock Text="Custom sigh (.wav / .mp3) — overrides generated tone"
                                   FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding Current.Critic.CustomSighSoundPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Browse…" Margin="8,0,0,0"
                                    Style="{StaticResource ActionButtonSecondary}"
                                    Click="BrowseCriticSound_Click"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Clear file" Style="{StaticResource ActionButtonSecondary}"
                                    Click="ClearCriticSound_Click"/>
                            <Button Content="Preview sigh" Style="{StaticResource ActionButtonPrimary}"
                                    Margin="8,0,0,0" Click="PreviewCriticSound_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Philosopher -->
                    <StackPanel Visibility="{Binding ShowPhilosopher, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom quote intervals (ignore severity presets)"
                                  IsChecked="{Binding Current.Philosopher.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"/>
                        <TextBlock Text="Min minutes between clipboard quotes" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="240"
                                Value="{Binding Current.Philosopher.MinIntervalMinutes}" Margin="0,4,0,8"/>
                        <TextBlock Text="Max minutes between clipboard quotes" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="240"
                                Value="{Binding Current.Philosopher.MaxIntervalMinutes}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Lag Ghost -->
                    <StackPanel Visibility="{Binding ShowLagGhost, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom lag timing (ignore severity presets)"
                                  IsChecked="{Binding Current.LagGhost.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"/>
                        <TextBlock Text="Min seconds between lag bursts" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="30" Maximum="86400"
                                Value="{Binding Current.LagGhost.OuterMinSeconds}" Margin="0,4,0,8"/>
                        <TextBlock Text="Max seconds between lag bursts" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="30" Maximum="86400"
                                Value="{Binding Current.LagGhost.OuterMaxSeconds}" Margin="0,4,0,8"/>
                        <TextBlock Text="Burst duration (seconds)" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="5" Maximum="600"
                                Value="{Binding Current.LagGhost.BurstDurationSeconds}" Margin="0,4,0,8"/>
                        <TextBlock Text="Per-move lag min (ms)" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="10" Maximum="3000"
                                Value="{Binding Current.LagGhost.LagDelayMinMs}" Margin="0,4,0,8"/>
                        <TextBlock Text="Per-move lag max (ms)" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="10" Maximum="3000"
                                Value="{Binding Current.LagGhost.LagDelayMaxMs}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Rearranger -->
                    <StackPanel Visibility="{Binding ShowRearranger, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom window nudge timing (ignore severity presets)"
                                  IsChecked="{Binding Current.Rearranger.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"/>
                        <TextBlock Text="Min minutes between nudges" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="1440"
                                Value="{Binding Current.Rearranger.MinIntervalMinutes}" Margin="0,4,0,8"/>
                        <TextBlock Text="Max minutes between nudges" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="1440"
                                Value="{Binding Current.Rearranger.MaxIntervalMinutes}" Margin="0,4,0,8"/>
                        <TextBlock Text="Max nudge (pixels)" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="2" Maximum="120"
                                Value="{Binding Current.Rearranger.MaxNudgePixels}" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>

<Window x:Class="Gremlins.UI.GremlinSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gremlins.UI"
        mc:Ignorable="d"
        Width="440" MinHeight="320" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BrushWindowBg}"
        Foreground="{DynamicResource BrushTextPrimary}"
        FontFamily="Segoe UI"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:GremlinSettingUnitConverter x:Key="GremlinUnits"/>
    </Window.Resources>

    <Border Padding="18" Background="{DynamicResource BrushBgCard}"
            CornerRadius="10" Margin="8"
            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Done" Style="{StaticResource ActionButtonPrimary}" Padding="20,10" Click="Done_Click" IsDefault="True"
                        ToolTip="Apply changes to preferences file immediately and close this window (settings also debounce-save while you edit)."/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560">
                <StackPanel>
                    <!-- Drifter -->
                    <StackPanel Visibility="{Binding ShowDrifter, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom timing &amp; drift (ignore severity presets)"
                                  IsChecked="{Binding Current.Drifter.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"
                                  ToolTip="When checked, intervals and drift below replace the Mischievous/Annoying/Unhinged timing for cursor nudges."/>
                        <TextBlock Text="Min interval — range 10–7200 s" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="10" Maximum="7200" TickFrequency="60" IsSnapToTickEnabled="False"
                                Value="{Binding Current.Drifter.MinIntervalSeconds}" Margin="0,4,0,2"
                                ToolTip="Shortest wait between random cursor moves (seconds). Used with Max to pick a random delay each cycle."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"
                                   Text="{Binding Current.Drifter.MinIntervalSeconds, Converter={StaticResource GremlinUnits}, ConverterParameter=Sec}"/>
                        <TextBlock Text="Max interval — range 10–7200 s" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="10" Maximum="7200"
                                Value="{Binding Current.Drifter.MaxIntervalSeconds}" Margin="0,4,0,2"
                                ToolTip="Longest wait between nudges. Should be ≥ Min; if reversed, the app clamps safely."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"
                                   Text="{Binding Current.Drifter.MaxIntervalSeconds, Converter={StaticResource GremlinUnits}, ConverterParameter=Sec}"/>
                        <TextBlock Text="Max drift — range 1–120 px per axis" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="120"
                                Value="{Binding Current.Drifter.MaxDriftPixels}" Margin="0,4,0,2"
                                ToolTip="Maximum horizontal/vertical offset applied each time (pixels). Larger = more noticeable jumps."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}"
                                   Text="{Binding Current.Drifter.MaxDriftPixels, Converter={StaticResource GremlinUnits}, ConverterParameter=Px}"/>
                    </StackPanel>

                    <!-- Typist -->
                    <StackPanel Visibility="{Binding ShowTypist, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom substitution chance (ignore severity presets)"
                                  IsChecked="{Binding Current.Typist.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"
                                  ToolTip="When on, the percentage below replaces severity-based swap odds for lookalike keys (l vs I, o vs 0, etc.)."/>
                        <TextBlock Text="Substitution chance — range 0.05–25 %" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="0.05" Maximum="25" SmallChange="0.05" LargeChange="1"
                                Value="{Binding Current.Typist.SubstitutionChancePercent}" Margin="0,4,0,2"
                                ToolTip="Approximate chance each matching keystroke is swapped for a similar character (low-level keyboard hook)."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}"
                                   Text="{Binding Current.Typist.SubstitutionChancePercent, Converter={StaticResource GremlinUnits}, ConverterParameter=PctKey}"/>
                    </StackPanel>

                    <!-- Amnesiac -->
                    <StackPanel Visibility="{Binding ShowAmnesiac, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom clear intervals (ignore severity presets)"
                                  IsChecked="{Binding Current.Amnesiac.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"
                                  ToolTip="When on, clipboard clears happen on your Min/Max minute schedule instead of severity defaults."/>
                        <TextBlock Text="Min minutes between clears — range 1–240 min" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="240"
                                Value="{Binding Current.Amnesiac.MinIntervalMinutes}" Margin="0,4,0,2"
                                ToolTip="Minimum minutes between silent clipboard clears."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"
                                   Text="{Binding Current.Amnesiac.MinIntervalMinutes, Converter={StaticResource GremlinUnits}, ConverterParameter=Min}"/>
                        <TextBlock Text="Max minutes between clears — range 1–240 min" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="240"
                                Value="{Binding Current.Amnesiac.MaxIntervalMinutes}" Margin="0,4,0,2"
                                ToolTip="Maximum minutes between clears; each interval is random between Min and Max."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}"
                                   Text="{Binding Current.Amnesiac.MaxIntervalMinutes, Converter={StaticResource GremlinUnits}, ConverterParameter=Min}"/>
                    </StackPanel>

                    <!-- Critic -->
                    <StackPanel Visibility="{Binding ShowCritic, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom poll interval (ignore severity preset timing)"
                                  IsChecked="{Binding Current.Critic.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"
                                  ToolTip="When on, foreground window title is checked every N seconds below instead of the default ~2s poll."/>
                        <TextBlock Text="Foreground window poll — range 1–120 s" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="120"
                                Value="{Binding Current.Critic.PollIntervalSeconds}" Margin="0,4,0,2"
                                ToolTip="How often to read the active window title for shame keywords (lower = more CPU wake-ups)."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,10"
                                   Text="{Binding Current.Critic.PollIntervalSeconds, Converter={StaticResource GremlinUnits}, ConverterParameter=Sec}"/>
                        <TextBlock Text="Extra title keywords (comma-separated, matched in window titles)" FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}" TextWrapping="Wrap"/>
                        <TextBox Margin="0,6,0,0" Text="{Binding Current.Critic.ExtraTitleKeywords, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Additional substrings (comma-separated) matched case-insensitively in the title bar. Added to built-in list (YouTube, Reddit, etc.)."/>
                        <TextBlock Text="Sigh volume — range 5–100 %" FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}" Margin="0,14,0,4"/>
                        <Slider Minimum="5" Maximum="100"
                                Value="{Binding Current.Critic.SighVolumePercent}" Margin="0,0,0,2"
                                ToolTip="Output volume for the sigh sound: built-in waveform or your custom WAV/MP3."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,10"
                                   Text="{Binding Current.Critic.SighVolumePercent, Converter={StaticResource GremlinUnits}, ConverterParameter=PctVol}"/>
                        <TextBlock Text="Custom sigh (.wav / .mp3) — overrides generated tone"
                                   FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding Current.Critic.CustomSighSoundPath, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Optional path to replacement audio. When missing or invalid, the synthesized sigh is used."/>
                            <Button Grid.Column="1" Content="Browse…" Margin="8,0,0,0"
                                    Style="{StaticResource ActionButtonSecondary}"
                                    Click="BrowseCriticSound_Click"
                                    ToolTip="Choose a WAV or MP3 file from disk."/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Clear file" Style="{StaticResource ActionButtonSecondary}"
                                    Click="ClearCriticSound_Click"
                                    ToolTip="Remove custom path and use the generated sigh again."/>
                            <Button Content="Preview sigh" Style="{StaticResource ActionButtonPrimary}"
                                    Margin="8,0,0,0" Click="PreviewCriticSound_Click"
                                    ToolTip="Play once using current volume and custom file (or generated if no file)."/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Philosopher -->
                    <StackPanel Visibility="{Binding ShowPhilosopher, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom quote intervals (ignore severity presets)"
                                  IsChecked="{Binding Current.Philosopher.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"
                                  ToolTip="When on, clipboard quote swaps use your minute range instead of severity-based spacing."/>
                        <TextBlock Text="Min minutes between clipboard quotes — range 1–240 min" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="240"
                                Value="{Binding Current.Philosopher.MinIntervalMinutes}" Margin="0,4,0,2"
                                ToolTip="Minimum time between replacing clipboard text with a random quote."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"
                                   Text="{Binding Current.Philosopher.MinIntervalMinutes, Converter={StaticResource GremlinUnits}, ConverterParameter=Min}"/>
                        <TextBlock Text="Max minutes between clipboard quotes — range 1–240 min" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="240"
                                Value="{Binding Current.Philosopher.MaxIntervalMinutes}" Margin="0,4,0,2"
                                ToolTip="Maximum gap between philosophy drops; actual delay is random between Min and Max minutes."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}"
                                   Text="{Binding Current.Philosopher.MaxIntervalMinutes, Converter={StaticResource GremlinUnits}, ConverterParameter=Min}"/>
                    </StackPanel>

                    <!-- Lag Ghost -->
                    <StackPanel Visibility="{Binding ShowLagGhost, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom lag timing (ignore severity presets)"
                                  IsChecked="{Binding Current.LagGhost.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"
                                  ToolTip="When on, burst spacing, duration, and per-move lag below replace severity defaults for mouse slowdown windows."/>
                        <TextBlock Text="Min seconds between lag bursts — range 30 s–24 h" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="30" Maximum="86400"
                                Value="{Binding Current.LagGhost.OuterMinSeconds}" Margin="0,4,0,2"
                                ToolTip="Soonest next lag burst may start after the previous one ended (seconds)."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"
                                   Text="{Binding Current.LagGhost.OuterMinSeconds, Converter={StaticResource GremlinUnits}, ConverterParameter=Sec}"/>
                        <TextBlock Text="Max seconds between lag bursts — range 30 s–24 h" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="30" Maximum="86400"
                                Value="{Binding Current.LagGhost.OuterMaxSeconds}" Margin="0,4,0,2"
                                ToolTip="Latest gap before another burst randomizes between Min/Max outer interval."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"
                                   Text="{Binding Current.LagGhost.OuterMaxSeconds, Converter={StaticResource GremlinUnits}, ConverterParameter=Sec}"/>
                        <TextBlock Text="Burst duration — range 5–600 s" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="5" Maximum="600"
                                Value="{Binding Current.LagGhost.BurstDurationSeconds}" Margin="0,4,0,2"
                                ToolTip="How long mouse movement stays artificially delayed once a burst begins (low-level hook sleeps per move)."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"
                                   Text="{Binding Current.LagGhost.BurstDurationSeconds, Converter={StaticResource GremlinUnits}, ConverterParameter=Sec}"/>
                        <TextBlock Text="Per-move lag min — range 10–3000 ms" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="10" Maximum="3000"
                                Value="{Binding Current.LagGhost.LagDelayMinMs}" Margin="0,4,0,2"
                                ToolTip="Minimum extra delay injected per mouse message during a burst."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"
                                   Text="{Binding Current.LagGhost.LagDelayMinMs, Converter={StaticResource GremlinUnits}, ConverterParameter=Ms}"/>
                        <TextBlock Text="Per-move lag max — range 10–3000 ms" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="10" Maximum="3000"
                                Value="{Binding Current.LagGhost.LagDelayMaxMs}" Margin="0,4,0,2"
                                ToolTip="Maximum per-move delay; each event picks a random value between Min and Max milliseconds."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}"
                                   Text="{Binding Current.LagGhost.LagDelayMaxMs, Converter={StaticResource GremlinUnits}, ConverterParameter=Ms}"/>
                    </StackPanel>

                    <!-- Rearranger -->
                    <StackPanel Visibility="{Binding ShowRearranger, Converter={StaticResource BoolToVis}}">
                        <CheckBox Content="Use custom window nudge timing (ignore severity presets)"
                                  IsChecked="{Binding Current.Rearranger.UseCustomSettings}"
                                  Foreground="{DynamicResource BrushTextPrimary}" Margin="0,0,0,10"
                                  ToolTip="When on, how often and how far the focused window shifts uses the sliders below instead of severity presets."/>
                        <TextBlock Text="Min minutes between nudges — range 1–1440 min (24 h)" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="1440"
                                Value="{Binding Current.Rearranger.MinIntervalMinutes}" Margin="0,4,0,2"
                                ToolTip="Shortest wait between small position changes of the foreground window."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"
                                   Text="{Binding Current.Rearranger.MinIntervalMinutes, Converter={StaticResource GremlinUnits}, ConverterParameter=Min}"/>
                        <TextBlock Text="Max minutes between nudges — range 1–1440 min (24 h)" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="1" Maximum="1440"
                                Value="{Binding Current.Rearranger.MaxIntervalMinutes}" Margin="0,4,0,2"
                                ToolTip="Longest wait between nudges; interval randomizes between Min and Max."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,0,8"
                                   Text="{Binding Current.Rearranger.MaxIntervalMinutes, Converter={StaticResource GremlinUnits}, ConverterParameter=Min}"/>
                        <TextBlock Text="Max nudge — range 2–120 px per axis" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                        <Slider Minimum="2" Maximum="120"
                                Value="{Binding Current.Rearranger.MaxNudgePixels}" Margin="0,4,0,2"
                                ToolTip="Largest horizontal or vertical shift applied each time (pixels)."/>
                        <TextBlock FontSize="10" Foreground="{DynamicResource BrushTextMuted}"
                                   Text="{Binding Current.Rearranger.MaxNudgePixels, Converter={StaticResource GremlinUnits}, ConverterParameter=Px}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colour palette -->
    <Color x:Key="BgDeep">#0D0D0F</Color>
    <Color x:Key="BgCard">#16161A</Color>
    <Color x:Key="BgCardHover">#1E1E24</Color>
    <Color x:Key="AccentGreen">#39FF14</Color>
    <Color x:Key="AccentGreenDim">#1A7A00</Color>
    <Color x:Key="AccentRed">#FF3A3A</Color>
    <Color x:Key="TextPrimary">#E8E8E8</Color>
    <Color x:Key="TextMuted">#6B6B7A</Color>
    <Color x:Key="BorderSubtle">#2A2A32</Color>

    <SolidColorBrush x:Key="BrushBgDeep"       Color="{StaticResource BgDeep}"/>
    <SolidColorBrush x:Key="BrushBgCard"       Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BrushAccentGreen"  Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="BrushAccentGreenDim" Color="{StaticResource AccentGreenDim}"/>
    <SolidColorBrush x:Key="BrushAccentRed"    Color="{StaticResource AccentRed}"/>
    <SolidColorBrush x:Key="BrushTextPrimary"  Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextMuted"    Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="BrushBorder"       Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="BrushTransparent"  Color="Transparent"/>

    <!-- Dropdown surface (popup + list) -->
    <SolidColorBrush x:Key="BrushComboDropBg"      Color="#15151C"/>
    <SolidColorBrush x:Key="BrushComboDropBorder" Color="#3D3D4A"/>
    <SolidColorBrush x:Key="BrushComboItemHover"  Color="#252A30"/>
    <SolidColorBrush x:Key="BrushComboItemSelected" Color="#1E3D28"/>

    <!-- Toggle Button (the big on/off per gremlin) -->
    <Style x:Key="ToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width"  Value="48"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="Track"
                                CornerRadius="13" Width="48" Height="26"
                                Background="{StaticResource BrushBorder}"/>
                        <Ellipse x:Name="Thumb"
                                 Width="20" Height="20"
                                 Fill="{StaticResource BrushTextMuted}"
                                 HorizontalAlignment="Left"
                                 Margin="3,0,0,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource BrushAccentGreenDim}"/>
                            <Setter TargetName="Thumb" Property="Fill"       Value="{StaticResource BrushAccentGreen}"/>
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="Thumb" Property="Margin"     Value="0,0,3,0"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Card border style -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background"   Value="{StaticResource BrushBgCard}"/>
        <Setter Property="BorderBrush"  Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding"      Value="16"/>
        <Setter Property="Margin"       Value="0,0,0,10"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1E1E24"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Dropdown list items: dark panel + readable text -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="Background" Value="{StaticResource BrushComboDropBg}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushComboItemHover}"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushComboItemSelected}"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushAccentGreen}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsHighlighted" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#254530"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushAccentGreen}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox: chrome + dark popup (fixes white system dropdown) -->
    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="Background" Value="#1E1E26"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="MinWidth" Value="130"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="MaxDropDownHeight" Value="220"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton"
                                              Focusable="False"
                                              ClickMode="Press"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" Padding="0"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Grid IsHitTestVisible="False" Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="Presenter"
                                                      Grid.Column="0"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <Path Grid.Column="1"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          Fill="{StaticResource BrushTextMuted}"
                                          Data="M 0 0 L 5 5 L 10 0 Z"
                                          Stretch="Uniform"
                                          Width="9" Height="5"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=Chrome}"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border x:Name="DropShadowBorder"
                                    Margin="0,4,0,0"
                                    Background="{StaticResource BrushComboDropBg}"
                                    BorderBrush="{StaticResource BrushComboDropBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    MinWidth="{Binding ActualWidth, ElementName=Chrome}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16"
                                                      ShadowDepth="4"
                                                      Direction="270"
                                                      Color="#000000"
                                                      Opacity="0.55"/>
                                </Border.Effect>
                                <ScrollViewer Margin="2"
                                              Padding="2"
                                              SnapsToDevicePixels="True"
                                              Background="Transparent">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.45"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#4A5A4E"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary action (Enable All) -->
    <Style x:Key="ActionButtonPrimary" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="#1A2A1C"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushAccentGreenDim}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14"
                                              ShadowDepth="0"
                                              Color="#39FF14"
                                              Opacity="0.18"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#23382A"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushAccentGreen}"/>
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="20"
                                                      ShadowDepth="0"
                                                      Color="#39FF14"
                                                      Opacity="0.42"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#152018"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary action (Disable All) -->
    <Style x:Key="ActionButtonSecondary" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="#1C1C22"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#26262E"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#5A4A4A"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#141418"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ScrollBar minimal style -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width"      Value="6"/>
    </Style>

</ResourceDictionary>

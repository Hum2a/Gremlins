<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colour palette -->
    <Color x:Key="BgDeep">#0D0D0F</Color>
    <Color x:Key="BgCard">#16161A</Color>
    <Color x:Key="BgCardHover">#1E1E24</Color>
    <Color x:Key="AccentGreen">#39FF14</Color>
    <Color x:Key="AccentGreenDim">#1A7A00</Color>
    <Color x:Key="AccentRed">#FF3A3A</Color>
    <Color x:Key="TextPrimary">#E8E8E8</Color>
    <Color x:Key="TextMuted">#6B6B7A</Color>
    <Color x:Key="BorderSubtle">#2A2A32</Color>

    <SolidColorBrush x:Key="BrushBgDeep"       Color="{StaticResource BgDeep}"/>
    <SolidColorBrush x:Key="BrushBgCard"       Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BrushAccentGreen"  Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="BrushAccentGreenDim" Color="{StaticResource AccentGreenDim}"/>
    <SolidColorBrush x:Key="BrushAccentRed"    Color="{StaticResource AccentRed}"/>
    <SolidColorBrush x:Key="BrushTextPrimary"  Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextMuted"    Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="BrushBorder"       Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="BrushTransparent"  Color="Transparent"/>

    <!-- Toggle Button (the big on/off per gremlin) -->
    <Style x:Key="ToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width"  Value="48"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="Track"
                                CornerRadius="13" Width="48" Height="26"
                                Background="{StaticResource BrushBorder}"/>
                        <Ellipse x:Name="Thumb"
                                 Width="20" Height="20"
                                 Fill="{StaticResource BrushTextMuted}"
                                 HorizontalAlignment="Left"
                                 Margin="3,0,0,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource BrushAccentGreenDim}"/>
                            <Setter TargetName="Thumb" Property="Fill"       Value="{StaticResource BrushAccentGreen}"/>
                            <Setter TargetName="Thumb" Property="Margin"     Value="25,0,0,0"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Card border style -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background"   Value="{StaticResource BrushBgCard}"/>
        <Setter Property="BorderBrush"  Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding"      Value="16"/>
        <Setter Property="Margin"       Value="0,0,0,10"/>
    </Style>

    <!-- Action button -->
    <Style x:Key="ActionButton" TargetType="Button">
        <Setter Property="Background"   Value="{StaticResource BrushBorder}"/>
        <Setter Property="Foreground"   Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"      Value="14,8"/>
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushAccentGreenDim}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox (severity selector) -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"        Value="#222228"/>
        <Setter Property="Foreground"        Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush"       Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness"   Value="1"/>
        <Setter Property="Padding"           Value="6,3"/>
        <Setter Property="FontSize"          Value="11"/>
        <Setter Property="MinWidth"          Value="110"/>
    </Style>

    <!-- ScrollBar minimal style -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width"      Value="6"/>
    </Style>

</ResourceDictionary>

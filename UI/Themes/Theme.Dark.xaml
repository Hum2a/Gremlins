<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Gremlins dark theme (original palette) -->
    <SolidColorBrush x:Key="BrushBgDeep" Color="#0D0D0F"/>
    <SolidColorBrush x:Key="BrushBgCard" Color="#16161A"/>
    <SolidColorBrush x:Key="BrushCardHover" Color="#1E1E24"/>
    <SolidColorBrush x:Key="BrushAccentGreen" Color="#39FF14"/>
    <SolidColorBrush x:Key="BrushAccentGreenDim" Color="#1A7A00"/>
    <SolidColorBrush x:Key="BrushAccentRed" Color="#FF3A3A"/>
    <SolidColorBrush x:Key="BrushTextPrimary" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="BrushTextMuted" Color="#6B6B7A"/>
    <SolidColorBrush x:Key="BrushBorder" Color="#2A2A32"/>
    <SolidColorBrush x:Key="BrushTransparent" Color="Transparent"/>

    <SolidColorBrush x:Key="BrushWindowBg" Color="#0D0D0F"/>
    <SolidColorBrush x:Key="BrushBorderOuter" Color="#2A2A32"/>
    <SolidColorBrush x:Key="BrushTitleBar" Color="#111114"/>
    <SolidColorBrush x:Key="BrushTitleAccent" Color="#39FF14"/>
    <SolidColorBrush x:Key="BrushFooterBg" Color="#111114"/>
    <SolidColorBrush x:Key="BrushCloseButtonFg" Color="#6B6B7A"/>

    <SolidColorBrush x:Key="BrushComboDropBg" Color="#15151C"/>
    <SolidColorBrush x:Key="BrushComboDropBorder" Color="#3D3D4A"/>
    <SolidColorBrush x:Key="BrushComboItemHover" Color="#252A30"/>
    <SolidColorBrush x:Key="BrushComboItemSelected" Color="#1E3D28"/>
    <SolidColorBrush x:Key="BrushComboMultiHighlight" Color="#254530"/>
    <SolidColorBrush x:Key="BrushComboChromeBg" Color="#1E1E26"/>
    <SolidColorBrush x:Key="BrushComboHoverBorder" Color="#4A5A4E"/>
    <Color x:Key="ColorPrimaryGlow">#FF39FF14</Color>

    <SolidColorBrush x:Key="BrushActionPrimaryBg" Color="#1A2A1C"/>
    <SolidColorBrush x:Key="BrushActionPrimaryBgHover" Color="#23382A"/>
    <SolidColorBrush x:Key="BrushActionPrimaryBgPressed" Color="#152018"/>
    <SolidColorBrush x:Key="BrushActionSecondaryBg" Color="#1C1C22"/>
    <SolidColorBrush x:Key="BrushActionSecondaryHover" Color="#26262E"/>
    <SolidColorBrush x:Key="BrushActionSecondaryBorderHover" Color="#5A4A4A"/>
    <SolidColorBrush x:Key="BrushActionSecondaryPressed" Color="#141418"/>

    <SolidColorBrush x:Key="BrushScrollBarTrack" Color="Transparent"/>
</ResourceDictionary>

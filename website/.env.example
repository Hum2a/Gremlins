# Public at build time (Vite). Copy to .env for local dev; set in Cloudflare Pages → Settings → Environment variables.
# Only if the site is served under a subpath (must start and end with /), e.g. GitHub Project Pages:
# VITE_BASE=/repo-name/
VITE_SUPPORT_EMAIL=you@example.com
# After the app is live, paste your Microsoft Store product page URL:
# VITE_MICROSOFT_STORE_URL=https://apps.microsoft.com/detail/...
